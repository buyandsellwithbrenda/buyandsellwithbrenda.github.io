<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BuyAndSellWithBrenda | Brenda Geraci, Realtor® – Keller Williams College Park</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{--black:#0d0d0d;--white:#fff;--gray-light:#f4f4f4;--gray-soft:#e8e8e8;--gray-mid:#b0b0b0;--gray-dark:#5a5a5a;--accent:#3a3a3a;--accent-light:#6e6e6e;--font-serif:'Playfair Display',serif;--font-sans:'Inter',sans-serif;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--font-sans);color:var(--black);background:var(--white);}
    nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;justify-content:space-between;align-items:center;padding:12px 50px;background:rgba(255,255,255,0.97);border-bottom:1px solid var(--gray-soft);}
    .nav-left{display:flex;align-items:center;gap:16px;}
    .nav-kw-logo{height:44px;width:auto;object-fit:contain;}
    .nav-divider{width:1px;height:30px;background:var(--gray-soft);}
    .nav-logo{font-family:var(--font-serif);font-size:1.05rem;letter-spacing:0.05em;color:var(--black);}
    .nav-logo span{color:var(--accent-light);}
    .nav-links{display:flex;gap:24px;list-style:none;}
    .nav-links a{text-decoration:none;color:var(--black);font-size:0.78rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;transition:color 0.2s;}
    .nav-links a:hover{color:var(--accent-light);}
    .nav-right{display:flex;align-items:center;gap:10px;}
    .nav-social a{color:var(--gray-dark);font-size:0.73rem;text-decoration:none;margin:0 3px;}
    .nav-cta{background:var(--black);color:var(--white);padding:10px 18px;font-size:0.74rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;margin-left:8px;}
    .hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;}
    .hero-bg{position:absolute;inset:0;background:url('data:image/jpeg;base64,') center/cover no-repeat;z-index:0;}
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(5,5,5,0.90) 0%,rgba(10,10,10,0.78) 60%,rgba(20,20,20,0.62) 100%);z-index:1;}
    .hero-inner{position:relative;z-index:2;display:grid;grid-template-columns:1fr 370px;gap:70px;align-items:center;max-width:1100px;margin:0 auto;width:100%;padding:120px 50px 80px;}
    .hero-eyebrow{display:inline-block;color:var(--gray-mid);font-size:0.7rem;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;margin-bottom:20px;border-bottom:1px solid #444;padding-bottom:5px;}
    .hero h1{font-family:var(--font-serif);font-size:clamp(2.4rem,5vw,4.2rem);color:var(--white);line-height:1.12;margin-bottom:20px;}
    .hero h1 em{color:var(--gray-mid);font-style:normal;}
    .hero-sub{color:#9a9a9a;font-size:1rem;font-weight:300;line-height:1.8;max-width:500px;margin-bottom:24px;}
    .hero-contact-bar{display:flex;gap:18px;flex-wrap:wrap;margin-bottom:22px;align-items:center;}
    .hero-contact-bar a{color:var(--gray-mid);font-size:0.82rem;text-decoration:none;}
    .hero-contact-bar span{color:#333;}
    .hero-social{display:flex;gap:10px;margin-bottom:28px;flex-wrap:wrap;}
    .hero-social a{color:#666;font-size:0.73rem;text-decoration:none;border:1px solid #333;padding:7px 12px;letter-spacing:0.08em;text-transform:uppercase;transition:all 0.2s;}
    .hero-social a:hover{color:var(--white);border-color:#888;}
    .hero-buttons{display:flex;gap:12px;flex-wrap:wrap;}
    .btn-primary{background:var(--white);color:var(--black);padding:14px 28px;font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;}
    .btn-outline{border:1px solid rgba(255,255,255,0.35);color:var(--white);padding:14px 28px;font-size:0.8rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;}
    .hero-photo-wrap{position:relative;}
    .hero-photo{width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top;display:block;}
    .hero-photo-badge{position:absolute;bottom:0;left:0;right:0;background:rgba(13,13,13,0.92);padding:16px 20px;}
    .agent-name{font-family:var(--font-serif);font-size:1.1rem;color:var(--white);}
    .agent-title{font-size:0.68rem;color:var(--gray-mid);letter-spacing:0.1em;text-transform:uppercase;margin-top:3px;}
    .stats-bar{background:var(--black);padding:30px 50px;display:flex;justify-content:center;gap:70px;flex-wrap:wrap;}
    .stat{text-align:center;}
    .stat-number{font-family:var(--font-serif);font-size:1.9rem;color:var(--white);font-weight:700;}
    .stat-label{font-size:0.68rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--gray-mid);margin-top:5px;}
    section{padding:90px 50px;}
    .section-eyebrow{display:block;font-size:0.68rem;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:var(--accent-light);margin-bottom:10px;}
    .section-title{font-family:var(--font-serif);font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:1.2;color:var(--black);margin-bottom:16px;}
    .section-sub{font-size:0.95rem;color:var(--gray-dark);line-height:1.8;max-width:560px;}
    .why{background:var(--gray-light);}
    .why-grid{display:grid;grid-template-columns:1fr 1fr;gap:70px;align-items:center;max-width:1100px;margin:0 auto;}
    .why-features{margin-top:32px;display:grid;grid-template-columns:1fr 1fr;gap:16px;}
    .feature-card{background:var(--white);padding:24px;border-left:3px solid var(--black);}
    .feature-card h4{font-family:var(--font-serif);font-size:0.98rem;margin-bottom:6px;}
    .feature-card p{font-size:0.84rem;color:var(--gray-dark);line-height:1.65;}
    .why-image{width:100%;height:500px;object-fit:cover;filter:grayscale(35%);}
    .listings{background:var(--white);}
    .listings-inner{max-width:1200px;margin:0 auto;}
    .listings-header{text-align:center;max-width:700px;margin:0 auto 48px;}
    .listings-section-label{font-family:var(--font-serif);font-size:1.4rem;color:var(--black);margin:50px 0 24px;padding-bottom:10px;border-bottom:2px solid var(--black);display:flex;align-items:center;gap:12px;}
    .listings-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
    .listings-grid-2col{display:grid;grid-template-columns:repeat(2,1fr);gap:28px;}
    .listing-card{background:var(--white);border:1px solid var(--gray-soft);overflow:hidden;transition:transform 0.2s,box-shadow 0.2s;}
    .listing-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,0.1);}
    .listing-img{width:100%;height:320px;object-fit:contain;background:#f4f4f4;display:block;}
    .listing-badge{font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:4px 10px;display:inline-block;margin:0 0 12px 0;}
    .listing-badge.active{background:#1a6e1a;color:var(--white);}
    .sold-badge{background:#c0392b;color:#fff;font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:4px 10px;display:inline-block;margin:0 0 10px 0;}
    .listing-body{padding:20px;}
    .listing-price{font-family:var(--font-serif);font-size:1.25rem;font-weight:700;margin-bottom:2px;}
    .listing-address{font-size:0.84rem;font-weight:600;color:var(--black);margin-bottom:2px;}
    .listing-city{font-size:0.78rem;color:var(--gray-dark);margin-bottom:8px;}
    .listing-details{display:flex;gap:10px;font-size:0.74rem;color:var(--accent-light);font-weight:600;letter-spacing:0.04em;margin-bottom:6px;flex-wrap:wrap;}
    .listing-meta{font-size:0.72rem;color:var(--gray-mid);margin-bottom:14px;line-height:1.5;}
    .listing-cta{display:block;text-align:center;background:var(--black);color:var(--white);padding:11px;font-size:0.72rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;transition:opacity 0.2s;}
    .listing-cta:hover{opacity:0.8;}
    .listings-cta-bar{text-align:center;margin-top:44px;}
    .home-value{background:#111;color:var(--white);text-align:center;}
    .home-value .section-title{color:var(--white);}
    .home-value .section-sub{color:#888;margin:0 auto 40px;}
    .lead-form{max-width:540px;margin:0 auto;display:flex;flex-direction:column;gap:12px;}
    .lead-form input,.lead-form select{width:100%;padding:14px 18px;background:#1c1c1c;border:1px solid #2e2e2e;color:var(--white);font-family:var(--font-sans);font-size:0.9rem;outline:none;transition:border-color 0.2s;}
    .lead-form input::placeholder{color:#555;}
    .lead-form input:focus,.lead-form select:focus{border-color:#888;}
    .lead-form select{color:#555;}
    .lead-form select option{background:#1c1c1c;color:var(--white);}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .lead-form button{background:var(--white);color:var(--black);padding:16px;font-size:0.86rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;border:none;cursor:pointer;}
    .form-disclaimer{font-size:0.72rem;color:#444;margin-top:4px;}
    .process{background:var(--white);}
    .process-inner{max-width:1100px;margin:0 auto;}
    .process-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:28px;margin-top:52px;}
    .step{text-align:center;padding:0 10px;}
    .step-num{width:48px;height:48px;border:2px solid var(--black);display:flex;align-items:center;justify-content:center;font-family:var(--font-serif);font-size:1.2rem;color:var(--black);margin:0 auto 16px;}
    .step h4{font-family:var(--font-serif);font-size:0.98rem;margin-bottom:8px;}
    .step p{font-size:0.84rem;color:var(--gray-dark);line-height:1.65;}
    .testimonials{background:var(--gray-light);}
    .testimonials-inner{max-width:1100px;margin:0 auto;}
    .testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px;}
    .testi-card{background:var(--white);padding:30px 26px;border-top:3px solid var(--black);}
    .testi-card p{font-size:0.88rem;line-height:1.8;color:#444;margin-bottom:20px;font-style:italic;}
    .testi-author{font-weight:700;font-size:0.82rem;letter-spacing:0.05em;text-transform:uppercase;}
    .testi-location{font-size:0.75rem;color:var(--gray-dark);margin-top:3px;}
    .stars{color:var(--black);font-size:0.86rem;letter-spacing:3px;margin-bottom:12px;}
    .google-reviews{background:var(--black);color:var(--white);}
    .google-reviews-inner{max-width:1100px;margin:0 auto;}
    .google-reviews .section-title{color:var(--white);}
    .google-header{display:flex;align-items:center;gap:24px;margin-bottom:48px;flex-wrap:wrap;}
    .google-score .big-num{font-family:var(--font-serif);font-size:4rem;color:var(--white);line-height:1;}
    .google-score .big-stars{font-size:1.3rem;letter-spacing:4px;color:#fbbc04;margin:6px 0;}
    .google-score .review-count{font-size:0.75rem;color:#777;letter-spacing:0.1em;text-transform:uppercase;}
    .google-divider{width:1px;height:80px;background:#2a2a2a;}
    .google-badge-text{font-size:0.85rem;color:#888;line-height:1.6;}
    .google-badge-text strong{color:var(--white);display:block;font-size:1rem;}
    .reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
    .review-card{background:#161616;padding:28px 24px;border:1px solid #222;}
    .review-stars{color:#fbbc04;font-size:0.9rem;letter-spacing:2px;margin-bottom:12px;}
    .review-text{font-size:0.88rem;color:#aaa;line-height:1.75;font-style:italic;margin-bottom:18px;}
    .review-author{display:flex;align-items:center;gap:12px;}
    .review-avatar{width:36px;height:36px;border-radius:50%;background:#2a2a2a;display:flex;align-items:center;justify-content:center;font-family:var(--font-serif);font-size:1rem;color:var(--white);flex-shrink:0;}
    .review-name{font-size:0.82rem;font-weight:600;color:var(--white);}
    .review-date{font-size:0.72rem;color:#555;margin-top:2px;}
    .google-cta{text-align:center;margin-top:40px;}
    .google-cta a{display:inline-flex;align-items:center;gap:8px;border:1px solid #333;color:#aaa;padding:12px 28px;font-size:0.78rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;}
    .areas{background:var(--white);text-align:center;}
    .areas-inner{max-width:1000px;margin:0 auto;}
    .areas-tagline{margin-top:18px;margin-bottom:26px;font-size:0.9rem;color:var(--gray-dark);}
    .areas-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:12px;margin-bottom:28px;}
    .area-pill{padding:12px 26px;border:1px solid var(--black);font-size:0.78rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--black);cursor:default;transition:all 0.25s;}
    .area-pill:hover{background:var(--black);color:var(--white);}
    .area-pill.secondary{border-color:var(--gray-mid);color:var(--gray-dark);}
    .area-pill.secondary:hover{background:var(--accent);color:var(--white);border-color:var(--accent);}
    .areas-note{font-size:0.82rem;color:var(--gray-mid);}
    .areas-note a{color:var(--black);font-weight:600;text-decoration:none;}
    .contact{background:#0a0a0a;color:var(--white);}
    .contact-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;}
    .contact .section-title{color:var(--white);}
    .contact .section-sub{color:#888;}
    .contact-details{margin-top:28px;display:flex;flex-direction:column;gap:18px;}
    .contact-item{display:flex;align-items:flex-start;gap:12px;}
    .contact-icon{font-size:1rem;margin-top:2px;opacity:0.5;}
    .contact-item-text{font-size:0.88rem;line-height:1.6;color:#bbb;}
    .contact-item-text a{color:#bbb;text-decoration:none;}
    .contact-item-label{font-size:0.66rem;letter-spacing:0.2em;text-transform:uppercase;color:#555;margin-bottom:2px;}
    .social-links{display:flex;gap:10px;margin-top:32px;flex-wrap:wrap;}
    .social-btn{display:flex;align-items:center;gap:7px;padding:10px 16px;border:1px solid #2a2a2a;color:#aaa;text-decoration:none;font-size:0.74rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;transition:all 0.2s;}
    .social-btn:hover{border-color:#888;color:var(--white);}
    .contact-form{display:flex;flex-direction:column;gap:12px;}
    .contact-form input,.contact-form textarea,.contact-form select{background:#161616;border:1px solid #252525;color:var(--white);padding:14px 16px;font-family:var(--font-sans);font-size:0.88rem;outline:none;transition:border-color 0.2s;width:100%;}
    .contact-form input::placeholder,.contact-form textarea::placeholder{color:#3a3a3a;}
    .contact-form input:focus,.contact-form textarea:focus,.contact-form select:focus{border-color:#555;}
    .contact-form select{color:#555;}
    .contact-form select option{background:#161616;color:var(--white);}
    .contact-form textarea{resize:vertical;min-height:110px;}
    .contact-form button{background:var(--white);color:var(--black);padding:15px;font-size:0.83rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;border:none;cursor:pointer;}
    .form-note{font-size:0.72rem;color:#444;margin-top:4px;}
    .cta-banner{background:var(--black);padding:80px 50px;text-align:center;border-top:1px solid #1a1a1a;}
    .cta-banner h2{font-family:var(--font-serif);font-size:clamp(1.8rem,3.5vw,2.6rem);color:var(--white);margin-bottom:14px;}
    .cta-banner p{font-size:0.95rem;max-width:460px;margin:0 auto 30px;color:#777;line-height:1.75;}
    .btn-white{background:var(--white);color:var(--black);padding:14px 38px;font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;display:inline-block;}
    footer{background:#050505;color:#444;padding:44px 50px;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:20px;}
    .footer-left{display:flex;align-items:flex-start;gap:18px;flex-wrap:wrap;}
    .footer-kw-logo{height:48px;width:auto;object-fit:contain;filter:brightness(0.45);}
    .footer-logo{font-family:var(--font-serif);font-size:1rem;color:var(--white);margin-bottom:7px;}
    .footer-logo span{color:#666;}
    .footer-info{font-size:0.76rem;line-height:1.9;}
    .footer-info a{color:#777;text-decoration:none;}
    .footer-social{display:flex;gap:9px;margin-top:12px;flex-wrap:wrap;}
    .footer-social a{color:#3a3a3a;font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;border:1px solid #1a1a1a;padding:5px 10px;transition:all 0.2s;}
    .footer-social a:hover{color:var(--white);border-color:#555;}
    .footer-bottom{width:100%;text-align:center;font-size:0.7rem;border-top:1px solid #0f0f0f;padding-top:20px;margin-top:12px;color:#282828;}
    .chat-btn{position:fixed;bottom:26px;right:26px;z-index:999;background:var(--black);color:var(--white);border:1px solid #2a2a2a;padding:13px 20px;font-size:0.76rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;gap:9px;box-shadow:0 4px 24px rgba(0,0,0,0.5);font-family:var(--font-sans);}
    .chat-dot{width:8px;height:8px;background:#4caf50;border-radius:50%;animation:pulse 1.5s infinite;flex-shrink:0;}
    @keyframes pulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.4);opacity:0.7;}}
    .chat-popup{position:fixed;bottom:82px;right:26px;z-index:998;background:var(--white);width:295px;box-shadow:0 8px 40px rgba(0,0,0,0.3);display:none;flex-direction:column;}
    .chat-popup.open{display:flex;}
    .chat-header{background:var(--black);color:var(--white);padding:14px 18px;font-family:var(--font-serif);font-size:0.98rem;display:flex;justify-content:space-between;align-items:center;}
    .chat-close{background:none;border:none;color:#888;cursor:pointer;font-size:1rem;}
    .chat-body{padding:18px;}
    .chat-body p{font-size:0.84rem;color:#555;line-height:1.65;margin-bottom:14px;}
    .chat-body a{display:block;text-align:center;background:var(--black);color:var(--white);padding:11px;font-size:0.76rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;margin-bottom:8px;}
    @media(max-width:1100px){.listings-grid{grid-template-columns:repeat(2,1fr);}}
    @media(max-width:900px){
      nav{padding:12px 18px;} .nav-links,.nav-social{display:none;}
      .hero-inner{grid-template-columns:1fr;gap:32px;padding:96px 22px 56px;}
      .hero-photo-wrap{max-width:280px;margin:0 auto;}
      section{padding:60px 22px;}
      .why-grid,.testi-grid,.process-steps,.contact-inner,.listings-grid,.listings-grid-2col,.reviews-grid{grid-template-columns:1fr;}
      .stats-bar{gap:28px;padding:24px 22px;}
      .why-features{grid-template-columns:1fr;}
      footer{flex-direction:column;padding:32px 22px;}
    }
  
    .buyers{padding:80px 0;border-top:1px solid var(--gray-soft);}
    .buyers-inner{max-width:1040px;margin:0 auto;padding:0 20px;}
    .buyers .section-title{text-align:left;margin-bottom:10px;}
    .buyers .section-intro{max-width:720px;font-size:0.92rem;color:var(--gray-dark);margin-bottom:32px;}
    .buyers-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;margin-bottom:28px;}
    .buyers-card{background:#fafafa;border:1px solid #eee;padding:18px 18px 16px;border-radius:4px;}
    .buyers-card h3{font-size:0.9rem;margin-bottom:8px;}
    .buyers-card p{font-size:0.82rem;color:var(--gray-dark);margin:0;}
    .buyers-cta{margin-top:10px;padding-top:12px;border-top:1px solid #eee;max-width:760px;}
    .buyers-cta p{font-size:0.86rem;color:var(--gray-dark);margin-bottom:14px;}
    .buyers-cta .btn-primary{display:inline-block;}
    @media (max-width:768px){.buyers-grid{grid-template-columns:1fr;}}


    .buyer-link-strip{padding:40px 0;border-top:1px solid #111;border-bottom:1px solid #111;background:#050505;margin-top:40px;}
    .buyer-link-inner{max-width:900px;margin:0 auto;padding:0 20px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:10px;}
    .buyer-link-inner p{margin:0;font-size:0.9rem;color:#f0f0f0;}
    .buyer-link-btn{display:inline-block;padding:9px 18px;border:1px solid #f0f0f0;color:#f0f0f0;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;}
    .buyer-link-btn:hover{background:#f0f0f0;color:#000;}
    @media(max-width:640px){.buyer-link-inner{flex-direction:column;align-items:flex-start;}}

</style>
</head>
<body>
<nav>
  <div class="nav-left">
